# AI провайдер: "ollama" (офлайн) немесе "openrouter" (бұлтты)
AI_PROVIDER=ollama

# Ollama (офлайн)
OLLAMA_BASE_URL=http://localhost:11434
# Модель таңдау:
#   qwen3.5:4b                                    — жылдам, 201 тіл (make use-qwen)
#   hf.co/inceptionai/Llama-3.1-Sherkala-8B-Chat  — қазақшаға арналған (make use-sherkala)
OLLAMA_MODEL=qwen3.5:4b

# OpenRouter (бұлтты, 300+ модель — https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=qwen/qwen3-235b-a22b

# Ауа райы (OpenWeatherMap тегін план)
WEATHER_API_KEY=your_api_key_here
DEFAULT_CITY=Алматы

# Piper TTS (офлайн дауыс)
PIPER_MODELS_DIR=~/.aidos/piper

# Музыка
MUSIC_DIR=~/Music

# Логтау
LOG_LEVEL=INFO
